<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <style>
    @page { size: A4; margin: 12mm 14mm 12mm; }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: "Times New Roman", Times, serif;
      font-size: 10pt;
      line-height: 1.35;
      color: #111;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
      background: #fff;
    }

    .page { width: 210mm; min-height: 297mm; }

    /* ───────────────── Header (matches screenshot) ───────────────── */
    .header { text-align: center; }
    .name {
      font-size: 22pt;
      font-weight: 700;
      margin-top: 2mm;
    }
    .title {
      font-size: 11pt;
      font-style: italic;
      margin-top: 1mm;
    }

    .contact {
      margin-top: 4mm;
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 10px 18px;
      font-size: 9pt;
      font-family: Arial, Helvetica, sans-serif;
      color: #222;
    }
    .contact-item { display: inline-flex; align-items: center; gap: 6px; white-space: nowrap; }
    .contact-item svg, .contact-item img { width: 11px; height: 11px; opacity: .9; }
    .contact a { color: #111; text-decoration: none; }
    .top-rule {
      margin: 5mm 0 4mm;
      border: none;
      border-top: 1px solid #222;
    }

    /* ───────────────── Section title with side lines ───────────────── */
    .section { margin-top: 5mm; }
    .section-title {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      font-family: Arial, Helvetica, sans-serif;
      font-size: 10pt;
      font-weight: 700;
      letter-spacing: .8px;
      text-transform: uppercase;
      color: #111;
      margin-bottom: 3mm;
    }
    .section-title::before,
    .section-title::after {
      content: "";
      flex: 1;
      border-top: 1px solid #222;
      transform: translateY(1px);
    }

    /* ───────────────── Summary ───────────────── */
    .summary-text {
      font-family: Arial, Helvetica, sans-serif;
      font-size: 9.6pt;
      color: #111;
    }
    .summary-text p { margin-bottom: 2mm; }

    /* ───────────────── Skills (3 columns like screenshot) ───────────────── */
    .skills-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 10mm;
    }
    .skill-block { font-family: Arial, Helvetica, sans-serif; }
    .skill-block-title {
      font-weight: 700;
      font-size: 9.6pt;
      margin-bottom: 1.2mm;
    }
    .skill-block-body {
      font-size: 9.3pt;
      color: #111;
      word-break: break-word;
    }

    /* ───────────────── Education ───────────────── */
    .edu-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 8mm;
      font-family: Arial, Helvetica, sans-serif;
    }
    .edu-left .edu-school { font-weight: 700; font-size: 9.8pt; }
    .edu-left .edu-degree { font-style: italic; font-size: 9.4pt; margin-top: 1mm; }
    .edu-right {
      text-align: right;
      font-size: 9.2pt;
      white-space: nowrap;
    }
    .edu-right .edu-location { margin-top: 1mm; }

    /* ───────────────── Experience (Professional Experience) ───────────────── */
    .exp-entry { margin-bottom: 4mm; font-family: Arial, Helvetica, sans-serif; }
    .exp-top {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 8mm;
    }
    .exp-company { font-weight: 700; font-size: 10pt; }
    .exp-dates { font-size: 9.2pt; white-space: nowrap; }
    .exp-role { font-style: italic; margin-top: 1mm; font-size: 9.4pt; }

    .exp-bullets {
      margin-top: 2mm;
      padding-left: 14px;
      font-size: 9.4pt;
    }
    .exp-bullets li { margin-bottom: 1.4mm; }

    /* Keep it clean on one page when possible */
    /* .section, .exp-entry { break-inside: avoid; } */

    
    .lang-grid{
      display:grid;
      grid-template-columns: 1fr 1fr;
      gap: 2mm 20mm;
      margin-top: 1mm;
      font-size: 9pt;
    }

    .lang-item{
      display:flex;
      align-items:center;
      gap:6px;
      justify-content: space-between;
    }
    .lang-bullet{
      font-size: 12pt;
      line-height: 0;
      transform: translateY(-1px);
    }
    .lang-dots {
      display: flex;
      gap: 4px;
    }
    .lang-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: #000;
    }
    .lang-dot-empty {
      background: transparent;
      border: 1px solid #999;
    }
  </style>
</head>

<body>
  <div class="page">

    <!-- Header -->
    <div class="header">
      <div class="name"><%= name %></div>
      <% if (jobTitle) { %>
        <div class="title"><%= jobTitle %></div>
      <% } %>

      <% if (contactItems && contactItems.length) { %>
        <div class="contact">
          <% contactItems.forEach(function(c) { %>
            <div class="contact-item">
              <% if (c.iconFile) { %><%- c.iconFile %><% } %>
              <% if (c.link) { %>
                <a href="<%= c.link %>"><%= c.text %></a>
              <% } else { %>
                <span><%= c.text %></span>
              <% } %>
            </div>
          <% }) %>
        </div>
      <% } %>

    </div>

    <!-- SUMMARY -->
    <% if (resume && resume.summary) { %>
      <div class="section">
        <div class="section-title">Summary</div>
        <div class="summary-text">
          <% String(resume.summary).split("\n").filter(Boolean).forEach(function(line){ %>
            <p><%= line %></p>
          <% }) %>
        </div>
      </div>
    <% } %>

    <!-- SKILLS (3 columns) -->
    <% if (skillGroups && skillGroups.length) { %>
      <div class="section">
        <div class="section-title">Skills</div>

        <% 
          // Split into 3 columns (like the screenshot)
          var cols = [[], [], []];
          skillGroups.forEach(function(sg, i){ cols[i % 3].push(sg); });
        %>

        <div class="skills-grid">
          <% cols.forEach(function(col){ %>
            <div>
              <% col.forEach(function(sg){ %>
                <div class="skill-block" style="margin-bottom: 3.5mm;">
                  <div class="skill-block-title"><%= sg.title %></div>
                  <div class="skill-block-body" style="word-wrap: break-word;"><% sg.skills.split('\n').filter(function(s){ return s.trim(); }).forEach(function(skill){ %><div><%= skill.trim() %></div><% }); %></div>
                </div>
              <% }) %>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <!-- PROFESSIONAL EXPERIENCE -->
    <% if (experiences && experiences.length) { %>
      <div class="section">
        <div class="section-title">Professional Experience</div>

        <% experiences.forEach(function(exp){ %>
          <div class="exp-entry">
            <div class="exp-top">
              <div class="exp-company"><%= exp.role || "" %></div>
              <div class="exp-dates"><%= exp.duration || "" %></div>
            </div>

            <div class="exp-role">
              <%= exp.company || "" %>
              <% if (exp.location || exp.workPosition) { %>
                — <%= [exp.location, exp.workPosition ? "(" + exp.workPosition + ")" : ""].filter(Boolean).join(" ") %>
              <% } %>
            </div>

            <% var items = (exp.items || []).filter(Boolean); %>
            <% if (items.length) { %>
              <ul class="exp-bullets">
                <% items.forEach(function(it){ %>
                  <li><%= it %></li>
                <% }) %>
              </ul>
            <% } %>
          </div>
        <% }) %>
      </div>
    <% } %>

    <!-- EDUCATION -->
    <% if (resume.educations && resume.educations.length > 0) { %>
      <div class="section">
        <div class="section-title">Education</div>
        <% resume.educations && resume.educations.forEach(function(edu) { %>
        <div class="edu-row">
          <div class="edu-left">
            <% if (edu.university) { %>
              <div class="edu-school"><%= edu.university %></div>
            <% } %>
            <% if (edu.degree) { %>
              <div class="edu-degree"><%= edu.degree %></div>
            <% } %>
            <% if (edu.gpa) { %>
              <div style="font-size:9pt;color:#555">GPA: <%= edu.gpa %></div>
            <% } %>
            <% if (edu.others) { %>
              <div style="font-size:9pt;color:#555"><%= edu.others %></div>
            <% } %>
          </div>
          <div class="edu-right">
            <% if (edu.duration) { %><div class="edu-dates"><%= edu.duration %></div><% } %>
            <% if (edu.location) { %><div class="edu-location"><%= edu.location %></div><% } %>
          </div>
        </div>
        <% }); %>
      </div>
    <% } %>

    <!-- CERTIFICATES -->
    <% if (resume.certificates && resume.certificates.length > 0) { %>
      <div class="section">
        <div class="section-title">Certificates</div>
        <% resume.certificates && resume.certificates.forEach(function(cert) { %>
        <div class="edu-row">
          <div class="edu-left">
            <div class="edu-school"><%= cert.name %></div>
            <% if (cert.org) { %><div class="edu-degree"><%= cert.org %></div><% } %>
          </div>
          <div class="edu-right">
            <% if (cert.date) { %><div class="edu-dates"><%= cert.date %></div><% } %>
          </div>
        </div>
        <% }); %>
      </div>
    <% } %>

    <!-- LANGUAGES -->
    <% if (languages && languages.length) { %>
      <div class="section">
        <div class="section-title">Languages</div>

        <div class="lang-grid">
          <% languages.forEach(function(l){ %>
            <div class="lang-item">
              <span><%= l.name %></span>
              <% if (l.level > 1) { %>
                <div class="lang-dots">
                  <% for (var d = 0; d < 5; d++) { %>
                    <span class="lang-dot<%= d < l.level ? '' : ' lang-dot-empty' %>"></span>
                  <% } %>
                </div>
              <% } %>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

  </div>
</body>
</html>