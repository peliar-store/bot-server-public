<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <style>
    @page {
      size: A4;
      margin: 0;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', 'Roboto', 'Noto Sans', Arial, sans-serif;
      font-size: 10pt;
      line-height: 1.35;
      color: #222;
      background: #fff;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }
    .page {
      width: 210mm;
      min-height: 297mm;
      display: flex;
    }
    /* ── Sidebar ──────────────────────────────── */
    .sidebar {
      width: 68mm;
      background: #1a2332;
      color: #e0e6ed;
      padding: 16mm 8mm 10mm;
      flex-shrink: 0;
      position: fixed;
      left: 0;
      top: 0;
      bottom: 0;
    }
    .sidebar-name {
      font-weight: 700;
      font-size: 16pt;
      line-height: 1.2;
      color: #fff;
      margin-bottom: 2px;
    }
    .sidebar-title {
      font-size: 10pt;
      color: #8ba3c4;
      font-style: italic;
      margin-bottom: 16px;
    }
    .sidebar-section { margin-bottom: 14px; }
    .sidebar-section-title {
      font-weight: 700;
      font-size: 9pt;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #8ba3c4;
      border-bottom: 1px solid #2e3e52;
      padding-bottom: 3px;
      margin-bottom: 8px;
    }
    .contact-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 8.5pt;
      margin-bottom: 5px;
      word-break: break-all;
    }
    .contact-item img {
      width: 10px;
      height: 10px;
      filter: brightness(0) invert(1);
    }
    .contact-item a {
      color: #c3d4ea;
      text-decoration: none;
    }
    .sidebar-skill-group { margin-bottom: 8px; }
    .sidebar-skill-title { font-weight: 600; font-size: 9pt; color: #fff; }
    .sidebar-skill-list { font-size: 8.5pt; color: #b8c9de; }
    .sidebar-lang { margin-bottom: 4px; display: flex; align-items: center; gap: 8px; }
    .sidebar-lang-name { font-size: 9pt; min-width: 48%; }
    .sidebar-lang-dots { display: flex; gap: 3px; }
    .sidebar-lang-dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: #8ba3c4;
    }
    .sidebar-lang-dot-empty {
      background: transparent;
      border: 1px solid #8ba3c4;
    }
    /* ── Main Column ──────────────────────────── */
    .main {
      flex: 1;
      padding: 16mm 12mm 10mm 10mm;
      -webkit-box-decoration-break: clone;
      box-decoration-break: clone;
      margin-left: calc(68mm);
    }
    .section { margin-bottom: 12px; }
    .section-title {
      font-weight: 700;
      font-size: 11pt;
      color: #1a2332;
      border-bottom: 2px solid #1a2332;
      padding-bottom: 2px;
      margin-bottom: 6px;
    }
    .summary-text { font-size: 10pt; color: #333; }
    .exp-entry { margin-bottom: 6px; }
    .exp-header { display: flex; justify-content: space-between; align-items: baseline; }
    .exp-role { font-weight: 700; font-size: 10pt; }
    .exp-company { font-style: italic; font-size: 10pt; color: #555; }
    .exp-right { font-size: 9pt; color: #666; text-align: right; white-space: nowrap; }
    .exp-bullets { list-style: disc; margin-left: 18px; font-size: 9.5pt; color: #333; }
    .exp-bullets li { margin-bottom: 1px; }
    .edu-header { display: flex; justify-content: space-between; align-items: baseline; }
    .edu-university { font-weight: 700; font-size: 10pt; }
    .edu-degree { font-style: italic; font-size: 10pt; color: #555; }
    .edu-right { font-size: 9pt; color: #666; text-align: right; white-space: nowrap; }
  </style>
</head>
<body>
  <div class="page">
    <!-- ── Sidebar ── -->
    <div class="sidebar">
      <div class="sidebar-name"><%= name %></div>
      <% if (jobTitle) { %>
        <div class="sidebar-title"><%= jobTitle %></div>
      <% } %>

      <% if (contactItems.length > 0) { %>
        <div class="sidebar-section">
          <div class="sidebar-section-title">Contact</div>
          <% contactItems.forEach(function(c) { %>
            <div class="contact-item" style="color: white;">
              <% if (c.iconFile) { %>
                <%- c.iconFile %>
              <% } %>
              <% if (c.link) { %>
                <a href="<%= c.link %>"><%= c.text %></a>
              <% } else { %>
                <span><%= c.text %></span>
              <% } %>
            </div>
          <% }); %>
        </div>
      <% } %>

      <% if (skillGroups.length > 0) { %>
        <div class="sidebar-section">
          <div class="sidebar-section-title">Skills</div>
          <% skillGroups.forEach(function(sg) { %>
            <div class="sidebar-skill-group">
              <div class="sidebar-skill-title"><%= sg.title %></div>
              <div class="sidebar-skill-list" style="word-wrap: break-word;"><% sg.skills.split('\n').filter(function(s){ return s.trim(); }).forEach(function(skill){ %><div><%= skill.trim() %></div><% }); %></div>
            </div>
          <% }); %>
        </div>
      <% } %>

      <% if (languages.length > 0) { %>
        <div class="sidebar-section">
          <div class="sidebar-section-title">Languages</div>
          <% languages.forEach(function(lang) { %>
            <div class="sidebar-lang">
              <span class="sidebar-lang-name"><%= lang.name %></span>
              <% if (lang.level > 1) { %>
                <div class="sidebar-lang-dots">
                  <% for (var d = 0; d < 5; d++) { %>
                    <span class="sidebar-lang-dot<%= d < lang.level ? '' : ' sidebar-lang-dot-empty' %>"></span>
                  <% } %>
                </div>
              <% } %>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>

    <!-- ── Main Column ── -->
    <div class="main">
      <% if (resume.summary) { %>
        <div class="section">
          <div class="section-title">Summary</div>
          <div class="summary-text"><%= resume.summary %></div>
        </div>
      <% } %>

      <% if (experiences.length > 0) { %>
        <div class="section">
          <div class="section-title">Professional Experience</div>
          <% experiences.forEach(function(exp) { %>
            <div class="exp-entry">
              <div class="exp-header">
                <div>
                  <span class="exp-role"><%= exp.role %></span>
                  <% if (exp.company) { %>
                    <p class="exp-company"><%= exp.company %></p>
                  <% } %>
                </div>
                <% if (exp.duration || exp.location || exp.workPosition) { %>
                  <div class="exp-right">
                    <p><%= exp.duration %></p>
                    <p><%= exp.location %><% if (exp.workPosition) { %> (<%= exp.workPosition %>)<% } %></p>
                  </div>
                <% } %>
              </div>
              <% var items = (exp.items || []).filter(Boolean); %>
              <% if (items.length > 0) { %>
                <ul class="exp-bullets">
                  <% items.forEach(function(item) { %>
                    <li><%= item %></li>
                  <% }); %>
                </ul>
              <% } %>
            </div>
          <% }); %>
        </div>
      <% } %>

      <% if (resume.educations && resume.educations.length > 0) { %>
        <div class="section">
          <div class="section-title">Education</div>
          <% resume.educations && resume.educations.forEach(function(edu) { %>
          <div class="edu-header">
            <div>
              <% if (edu.university) { %>
                <div class="edu-university"><%= edu.university %></div>
              <% } %>
              <% if (edu.degree) { %>
                <div class="edu-degree"><%= edu.degree %></div>
              <% } %>
              <% if (edu.gpa) { %>
                <div style="font-size:8pt;color:#aaa">GPA: <%= edu.gpa %></div>
              <% } %>
              <% if (edu.others) { %>
                <div style="font-size:8pt;color:#aaa"><%= edu.others %></div>
              <% } %>
            </div>
            <% if (edu.duration || edu.location) { %>
              <div class="edu-right">
                <% if (edu.duration) { %><p><%= edu.duration %></p><% } %>
                <% if (edu.location) { %><p><%= edu.location %></p><% } %>
              </div>
            <% } %>
          </div>
          <% }); %>
        </div>
      <% } %>

      <% if (resume.certificates && resume.certificates.length > 0) { %>
        <div class="section">
          <div class="section-title">Certificates</div>
          <% resume.certificates && resume.certificates.forEach(function(cert) { %>
          <div class="edu-header">
            <div>
              <div class="edu-university"><%= cert.name %></div>
              <% if (cert.org) { %><div class="edu-degree"><%= cert.org %></div><% } %>
            </div>
            <% if (cert.date) { %>
              <div class="edu-right"><p><%= cert.date %></p></div>
            <% } %>
          </div>
          <% }); %>
        </div>
      <% } %>
    </div>
  </div>
</body>
</html>
