<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <style>
    @page { size: A4; margin: 0; }

    :root{
      --bg:#ffffff;
      --header:#2f2f2f;
      --accent:#f5b300;      /* yellow */
      --text:#111;
      --muted:#444;
      --rule:#d7d7d7;
      --sans: Arial, Helvetica, sans-serif;
      --serif: "Times New Roman", Times, serif;
    }

    *{ margin:0; padding:0; box-sizing:border-box; }
    body{
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      font-size: 10pt;
      line-height: 1.35;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
      display: flex;
      flex-direction: column;
    }

    /* Page padding like screenshot (content inset) */
    .wrap{
      padding: 8mm 10mm 10mm;
    }

    /* ───────── Header (dark bar) ───────── */
    .header{
      background: var(--header);
      padding: 10mm 14mm 8mm;
      color: #fff;
    }

    .name{
      font-family: var(--sans);
      font-weight: 800;
      font-size: 24pt;
      color: var(--accent);
      margin-bottom: 2mm;
    }

    .title{
      font-size: 13pt;
      color: var(--accent);
      margin-bottom: 5mm;
    }

    .contacts{
      display:flex;
      flex-wrap:wrap;
      gap: 7px 18px;
      align-items:center;
      font-size: 9pt;
      color:#fff;
      opacity: .95;
    }
    .contact-item{
      display:inline-flex;
      align-items:center;
      gap: 7px;
      white-space: nowrap;
    }
    .contact-item a{
      color:#fff;
      text-decoration:none;
    }
    .contact-item svg, .contact-item img{
      width: 12px;
      height: 12px;
      fill: var(--accent);
      opacity: 1;
    }

    /* Divider below header */
    .header-rule{
      border: none;
      border-top: 2px solid #1f1f1f;
      margin: 0;
    }

    /* ───────── Section headings (icon + label + yellow underline) ───────── */
    .section{
      margin-top: 6mm;
    }

    .section-head{
      display:flex;
      align-items:center;
      gap: 8px;
      font-weight: 800;
      letter-spacing: .6px;
      text-transform: uppercase;
      font-size: 10pt;
      color:#111;
    }

    .sec-ico{
      width: 14px; height: 14px; fill:#111;
      flex: 0 0 auto;
    }

    .section-underline{
      margin-top: 2mm;
      width: 22px;
      height: 4px;
      background: var(--accent);
      border-radius: 1px;
    }

    .para{
      margin-top: 3mm;
      color:#111;
      font-size: 9.6pt;
    }

    /* ───────── Skills layout (3 columns like screenshot) ───────── */
    .skills-grid{
      margin-top: 4mm;
      display:grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 8mm 3mm;
    }

    .skill-block-title{
      font-weight: 800;
      font-size: 9.6pt;
      margin-bottom: 1mm;
      color:#111;
    }
    .skill-block-body{
      font-size: 9.2pt;
      color:#111;
    }

    /* ───────── Education row (right aligned dates/location in accent) ───────── */
    .edu-row{
      margin-top: 4mm;
      display:flex;
      justify-content: space-between;
      gap: 10mm;
      align-items: baseline;
    }
    .edu-left{
      font-size: 9.4pt;
      color:#111;
    }
    .edu-right{
      text-align:right;
      white-space:nowrap;
      font-size: 9.2pt;
    }
    .edu-right .date{
      color: var(--accent);
      font-weight: 800;
    }

    /* ───────── Languages line (Romanian | English) ───────── */
    .lang-line{
      margin-top: 4mm;
      font-size: 9.4pt;
      color:#111;
    }
    .lang-sep{
      color:#888;
      padding: 0 8px;
    }

    /* ───────── Experience entries ───────── */
    .exp-entry{
      margin-top: 4mm;
    }

    .exp-top{
      display:flex;
      justify-content: space-between;
      gap: 10mm;
      align-items: baseline;
      margin-bottom: 1mm;
    }

    .exp-role{
      font-weight: 800;
      font-size: 9.8pt;
      color:#111;
    }

    .exp-company{
      font-style: italic;
      color:#111;
      margin-top: 1mm;
      font-size: 9.4pt;
    }

    .exp-meta{
      text-align:right;
      white-space:nowrap;
      font-size: 9pt;
      color:#111;
    }
    .exp-meta .date{
      color: var(--accent);
      font-weight: 800;
    }

    .bullets{
      margin-top: 2.5mm;
      padding-left: 18px;
      font-size: 9.4pt;
      color:#111;
    }
    .bullets li{ margin-bottom: 1.3mm; }

    /* Small spacing helpers */
    .mt2 { margin-top: 2mm; }
  </style>
</head>

<body>

  <!-- DARK HEADER -->
  <div class="header">
    <div class="name"><%= name %></div>
    <% if (jobTitle) { %>
      <div class="title"><%= jobTitle %></div>
    <% } %>

    <% if (contactItems && contactItems.length) { %>
      <div class="contacts">
        <% contactItems.forEach(function(c){ %>
          <div class="contact-item">
            <% if (c.iconFile) { %><%- c.iconFile %><% } %>
            <% if (c.link) { %>
              <a href="<%= c.link %>"><%= c.text %></a>
            <% } else { %>
              <span><%= c.text %></span>
            <% } %>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
  <hr class="header-rule" />

  <div class="wrap">

    <!-- SUMMARY -->
    <% if (resume && resume.summary) { %>
      <div class="section">
        <div class="section-head">
          <!-- brief summary icon -->
          <svg class="sec-ico" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 4h16v4H4V4zm0 6h16v10H4V10zm3 2v2h10v-2H7zm0 4v2h7v-2H7z"/>
          </svg>
          <div>Summary</div>
        </div>
        <div class="section-underline"></div>

        <div class="para">
          <% String(resume.summary).split("\n").filter(Boolean).forEach(function(line){ %>
            <div><%= line %></div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <!-- SKILLS -->
    <% if (skillGroups && skillGroups.length) { %>
      <div class="section">
        <div class="section-head">
          <svg class="sec-ico" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M22 19.6l-6.3-6.3a7 7 0 0 1-8.9-8.9l3.2 3.2 2.1-2.1-3.2-3.2a7 7 0 0 1 8.9 8.9L24 17.5 22 19.6zM2.6 21.4l7.3-7.3 2 2-7.3 7.3a1.4 1.4 0 0 1-2-2z"/>
          </svg>
          <div>Skills</div>
        </div>
        <div class="section-underline"></div>

        <% 
          // Split into 3 columns (like the screenshot)
          var cols = [[], [], []];
          skillGroups.forEach(function(sg, i){ cols[i % 3].push(sg); });
        %>

        <div class="skills-grid">
          <% cols.forEach(function(col){ %>
            <div>
              <% col.forEach(function(sg){ %>
                <div class="skill-block" style="margin-bottom: 3.5mm;">
                  <div class="skill-block-title"><%= sg.title %></div>
                  <div class="skill-block-body" style="word-wrap: break-word;"><% sg.skills.split('\n').filter(function(s){ return s.trim(); }).forEach(function(skill){ %><div><%= skill.trim() %></div><% }); %></div>
                </div>
              <% }) %>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <!-- PROFESSIONAL EXPERIENCE -->
    <% if (experiences && experiences.length) { %>
      <div class="section">
        <div class="section-head">
          <svg class="sec-ico" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M10 2h4a2 2 0 012 2v2h4a2 2 0 012 2v10a2 2 0 01-2 2H4a2 2 0 01-2-2V8a2 2 0 012-2h4V4a2 2 0 012-2zm0 4h4V4h-4v2z"/>
          </svg>
          <div>Professional Experience</div>
        </div>
        <div class="section-underline"></div>

        <% experiences.forEach(function(exp){ %>
          <div class="exp-entry">
            <div class="exp-top">
              <div>
                <div class="exp-role"><%= exp.role || "" %><% if (exp.company) { %>, <em><%= exp.company %></em><% } %></div>
              </div>

              <div class="exp-meta">
                <% if (exp.duration) { %><div class="date"><%= exp.duration %></div><% } %>
                <% if (exp.location) { %><div><%= exp.location %><% if (exp.workPosition) { %> (<%= exp.workPosition %>)<% } %></div><% } %>
              </div>
            </div>

            <% var items = (exp.items || []).filter(Boolean); %>
            <% if (items.length) { %>
              <ul class="bullets">
                <% items.forEach(function(it){ %>
                  <li><%= it %></li>
                <% }) %>
              </ul>
            <% } %>
          </div>
        <% }) %>
      </div>
    <% } %>

    <!-- EDUCATION -->
    <% if (resume.educations && resume.educations.length > 0) { %>
      <div class="section">
        <div class="section-head">
          <svg class="sec-ico" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 3L1 9l11 6 9-4.9V17h2V9L12 3zm0 14L4 12.7V16c0 2.8 3.6 5 8 5s8-2.2 8-5v-3.3L12 17z"/>
          </svg>
          <div>Education</div>
        </div>
        <div class="section-underline"></div>
        <% resume.educations && resume.educations.forEach(function(edu) { %>
        <div class="edu-row">
          <div class="edu-left">
            <% if (edu.degree) { %>
              <div><strong><%= edu.degree %></strong><% if (edu.university) { %>, <em><%= edu.university %></em><% } %></div>
            <% } else if (edu.university) { %>
              <div><strong><%= edu.university %></strong></div>
            <% } %>
            <% if (edu.gpa) { %><div style="font-size:8pt;color:#666">GPA: <%= edu.gpa %></div><% } %>
            <% if (edu.others) { %><div style="font-size:8pt;color:#666"><%= edu.others %></div><% } %>
          </div>
          <div class="edu-right">
            <% if (edu.duration) { %><div class="date"><%= edu.duration %></div><% } %>
            <% if (edu.location) { %><div><%= edu.location %></div><% } %>
          </div>
        </div>
        <% }); %>
      </div>
    <% } %>

    <!-- CERTIFICATES -->
    <% if (resume.certificates && resume.certificates.length > 0) { %>
      <div class="section">
        <div class="section-head">
          <svg class="sec-ico" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/>
          </svg>
          <div>Certificates</div>
        </div>
        <div class="section-underline"></div>
        <% resume.certificates && resume.certificates.forEach(function(cert) { %>
        <div class="edu-row">
          <div class="edu-left">
            <div><strong><%= cert.name %></strong><% if (cert.org) { %>, <em><%= cert.org %></em><% } %></div>
          </div>
          <div class="edu-right">
            <% if (cert.date) { %><div class="date"><%= cert.date %></div><% } %>
          </div>
        </div>
        <% }); %>
      </div>
    <% } %>

    <!-- LANGUAGES (Romanian | English) -->
    <% if (languages && languages.length) { %>
      <div class="section">
        <div class="section-head">
          <svg class="sec-ico" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2a10 10 0 100 20 10 10 0 000-20zm7.9 9h-3.2a15.6 15.6 0 00-1.2-5A8.1 8.1 0 0119.9 11zM12 4.1c.9 1.2 1.8 3.4 2.2 6H9.8c.4-2.6 1.3-4.8 2.2-6zM4.1 13h3.2c.2 1.8.7 3.5 1.2 5A8.1 8.1 0 014.1 13zm3.2-2H4.1a8.1 8.1 0 014.4-5c-.5 1.5-1 3.2-1.2 5zm2.5 2h4.4c-.4 2.6-1.3 4.8-2.2 6-.9-1.2-1.8-3.4-2.2-6zm6.1 5c.5-1.5 1-3.2 1.2-5h3.2a8.1 8.1 0 01-4.4 5z"/>
          </svg>
          <div>Languages</div>
        </div>
        <div class="section-underline"></div>

        <div class="lang-line">
          <% languages.forEach(function(l, idx){ %>
            <span><%= (typeof l === "string") ? l : (l.name || "") %></span>
            <% if (idx < languages.length - 1) { %>
              <span class="lang-sep">|</span>
            <% } %>
          <% }) %>
        </div>
      </div>
    <% } %>


  </div>
</body>
</html>