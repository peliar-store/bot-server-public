<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <style>
    @page { size: A4; margin: 14mm 14mm 14mm; }

    :root{
      /* Match the provided reference style (teal headings, clean black text) */
      --teal:#0b7b70;
      --text:#111;
      --muted:#333;
      --rule:#111;
    }

    *{ margin:0; padding:0; box-sizing:border-box; }
    body{
      font-family: Arial, Helvetica, sans-serif;
      font-size: 9.6pt;
      line-height: 1.28;
      color: var(--text);
      background:#fff;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }
    .page{ width:210mm; min-height:297mm; }

    /* Header (LEFT-aligned like the reference) */
    .header{ text-align:left; margin-bottom: 4mm; }
    .name{
      font-size: 20pt;
      font-weight: 800;
      color: var(--teal);
      margin-bottom: 1.5mm;
    }
    .title{ font-size: 10.6pt; font-weight: 700; color:#111; margin-top: 2.4mm; margin-bottom: 5px; }

    .contacts{
      display:flex;
      justify-content:flex-start;
      align-items:center;
      flex-wrap:wrap;
      font-size: 8.6pt;
      color:#111;
    }
    .contact-item{ display:inline-flex; align-items:center; }
    .contact-item a{ color:#111; text-decoration:none; }
    .contact-sep{ margin: 0 6px; color:#111; }

    .header-rule{ border: none; border-top: 1px solid #111; margin-top: 2.6mm; }

    /* Section title + rule (teal title like the reference) */
    .section{ margin-top: 4.5mm; }
    .section-title{
      font-size: 9.2pt;
      font-weight: 800;
      letter-spacing: .6px;
      text-transform: uppercase;
      color: var(--teal);
      margin-bottom: 1.6mm;
    }
    .rule{ border: none; border-top: 1px solid var(--rule); margin-bottom: 2.6mm; }

    /* Summary */
    .summary{ font-size: 9.4pt; color:#111; }

    /* Skills (inline groups) */
    .skills-list{ font-size: 9.1pt; }
    .skill-group{ margin-bottom: 1.6mm; }
    .skill-title{ font-weight: 700; color:#111; }
    .skill-items{ color:#111; }

    /* Experience (company/location line + role line) */
    .exp-entry{ margin-bottom: 4.2mm;  }
    .exp-top{
      display:flex;
      justify-content: space-between;
      gap: 10mm;
      align-items: baseline;
    }
    .exp-left{ font-size: 9.6pt; font-weight: 700; color:#111; }
    .exp-right{
      text-align:right;
      white-space:nowrap;
      font-size: 8.8pt;
      color:#111;
    }

    .exp-role{ font-size: 9.3pt; font-weight: 700; color:#111; margin-top: .6mm; }

    .bullets{
      list-style: none;
      padding-left: 0;
      margin-top: 1mm;
      font-size: 9.1pt;
      color:#111;
    }
    .bullets li{
      position: relative;
      padding-left: 14px;
      margin-bottom: 1.4mm;
    }
    .bullets li::before{
      content:"-";
      position:absolute;
      left:0;
      top:0;
      color:#111;
    }

    /* Education */
    .edu-row{
      display:flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 10mm;
      font-size: 9.1pt;
    }
    .edu-left{ color:#111; }
    .edu-left strong{ font-weight: 800; }
    .edu-left em{ font-style: italic; }
    .edu-right{ text-align:right; white-space:nowrap; font-size: 8.8pt; color:#111; }

    /* Languages inline */
    .lang-inline{ font-size: 9.1pt; }
  </style>
</head>
<body>
  <div class="page">

    <!-- Header -->
    <div class="header">
      <div class="name"><%= name %></div>
      <% if (jobTitle) { %>
        <!-- In the reference, the title is shown under the header rule -->
      <% } %>

      <% if (contactItems && contactItems.length) { %>
        <div class="contacts">
          <% contactItems.forEach(function(c, idx){ %>
            <span class="contact-item">
              <% if (c.link) { %>
                <a href="<%= c.link %>"><%= c.text %></a>
              <% } else { %>
                <span><%= c.text %></span>
              <% } %>
            </span>
            <% if (idx !== contactItems.length - 1) { %>
              <span class="contact-sep">–</span>
            <% } %>
          <% }) %>
        </div>
      <% } %>

      <hr class="header-rule" />

    </div>

    <!-- Summary -->
    <% if (resume && resume.summary) { %>
      <div class="section">
      <% if (resume.name) { %>
        <div class="title"><%= resume.name %></div>
      <% } %>
        <div class="summary"><%= resume.summary %></div>
      </div>
    <% } %>

    <!-- Skills -->
    <% if (skillGroups && skillGroups.length) { %>
      <div class="section">
        <div class="section-title">Skills</div>
        <hr class="rule" />
        <div class="skills-list">
          <% skillGroups.forEach(function(sg){ %>
            <div class="skill-group">
              <span class="skill-title"><%= sg.title %>:</span>
              <span class="skill-items" style="word-wrap: break-word;">
                <% 
                  // Render as one clean line (like the reference), but keep the same variable.
                  var skillsInline = (sg.skills || '').split('\n').map(function(s){ return s.trim(); }).filter(Boolean).join(', ');
                %>
                <%= skillsInline %>
              </span>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <!-- Certifications (optional, keeps backend variables intact) -->
    <% if (resume.certificates && resume.certificates.length > 0) { %>
      <div class="section">
        <div class="section-title">Certifications</div>
        <hr class="rule" />

        <ul class="bullets">
          <% resume.certificates && resume.certificates.forEach(function(c){ %>
            <p style="margin-top: 5px;">
              <% if (typeof c === 'string') { %>
                <strong><%= c %></strong>
              <% } else { %>
                <span style="font-weight: 700;"><%= c.name || '' %></span><% if (c.date) { %> — <%= c.date %><% } %>
              <% } %>
              <% if (c.org) { %><div><%= c.org %></div><% } %>
            </p>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <!-- Professional Experience -->
    <% if (experiences && experiences.length) { %>
      <div class="section">
        <div class="section-title">Professional Experience</div>
        <hr class="rule" />

        <% experiences.forEach(function(exp){ %>
          <div class="exp-entry">
            <!-- Line 1: Company - Location (left) | Dates (right) -->
            <div class="exp-top">
              <div class="exp-left">
                <% if (exp.company) { %><%= exp.company %><% } %><% if (exp.location && exp.company) { %> – <% } %><% if (exp.location) { %><%= exp.location %><% } %>
              </div>
            </div>

            <!-- Line 2: Role (optionally with work position) -->
            <% if (exp.role || exp.workPosition) { %>
              <div class="exp-role">
                <% if (exp.role) { %><%= exp.role %><% } %>
                <% if (exp.duration) { %> - <%= exp.duration %><% } %>
              </div>
            <% } %>

            <% var items = (exp.items || []).filter(Boolean); %>
            <% if (items.length) { %>
              <ul class="bullets">
                <% items.forEach(function(it){ %>
                  <li><%= it %></li>
                <% }) %>
              </ul>
            <% } %>
          </div>
        <% }) %>
      </div>
    <% } %>

    <!-- Education -->
    <% if (resume && (resume.educations && resume.educations.length > 0)) { %>
      <div class="section">
        <div class="section-title">Education</div>
        <hr class="rule" />
        <% resume.educations.forEach(function(edu) { %>
          <div class="edu-row">
            <div class="edu-left">
              <% if (edu.university) { %>
                <div style="font-weight: 700;"><%= edu.university %></div>
              <% } %>
              <% if (edu.degree) { %>
                <div>
                  <%= edu.degree %>
                  <% if (edu.gpa) { %> — GPA: <%= edu.gpa %><% } %>
                  <% if (edu.duration) { %> — <%= edu.duration %><% } %>
                  <% if (edu.location) { %> — <%= edu.location %><% } %>
                </div>
                <div>
                  <% if (edu.others) { %><%= edu.others %><% } %>
                </div>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>

  </div>
</body>
</html>
