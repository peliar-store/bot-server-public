<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <style>
    @page { size: A4; margin: 12mm 14mm; }

    :root{
      --orange:#f39a1f;
      --ink:#111;
      --muted:#444;
      --serif: Georgia, "Times New Roman", Times, serif;
      --sans: Arial, Helvetica, sans-serif;
    }

    *{ margin:0; padding:0; box-sizing:border-box; }
    body{
      font-family: var(--sans);
      font-size: 9.5pt;
      line-height: 1.32;
      color: var(--ink);
      background:#fff;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .page{ width:210mm; min-height:297mm; }

    /* ───────────── Header (name + italic title on same line) ───────────── */
    .header{ margin-bottom: 6mm; }
    .name-row{ display:flex; align-items:baseline; gap:10px; flex-wrap:wrap; }
    .name{
      font-family: var(--serif);
      font-weight: 700;
      font-size: 22pt;
      color: var(--ink);
    }
    .title{
      font-family: var(--serif);
      font-style: italic;
      font-size: 11pt;
      color: #222;
    }

    .contacts{
      margin-top: 3mm;
      display:flex;
      flex-wrap:wrap;
      gap: 6px 18px;
      font-size: 9pt;
      color: var(--ink);
      align-items:center;
    }
    .contact-item{ display:inline-flex; align-items:center; gap:7px; white-space:nowrap; }
    .contact-item a{ color: var(--ink); text-decoration:none; }
    .contact-item svg{ width: 12px; height: 12px; }
    /* force icon color to orange (works for most inline SVGs) */
    .contact-item svg, .contact-item svg *{ fill: var(--orange) !important; stroke: var(--orange) !important; }

    /* ───────────── Layout: sidebar left, main right ───────────── */
    .grid{
      display:grid;
      grid-template-columns: 33% 67%;
      gap: 10mm;
      align-items:start;
    }

    /* ───────────── Sidebar summary (no title, just text) ───────────── */
    .summary{
      font-size: 9.2pt;
      color: var(--muted);
      margin-bottom: 7mm;
      white-space: pre-line;
    }

    /* ───────────── Section header with icon + orange underline ───────────── */
    .section{ margin-bottom: 8mm; }
    .section-head{ display:flex; align-items:center; gap:8px; }
    .section-head .label{
      font-weight: 800;
      font-size: 10pt;
      letter-spacing: .6px;
      text-transform: uppercase;
    }
    .section-head .icon{ width: 14px; height: 14px; fill: var(--ink); }
    .section-rule{ border:none; border-top: 2px solid var(--orange); margin: 2mm 0 3mm; }

    /* ───────────── Skills blocks (title inline + content) ───────────── */
    .skill-group{ margin-bottom: 3mm; }
    .skill-title{ font-weight: 800; font-size: 9.2pt; }
    .skill-items{ font-size: 9.1pt; color:#222; }

    /* ───────────── Education ───────────── */
    .edu-degree{ font-weight: 800; font-size: 9.2pt; }
    .edu-school{ font-weight: 800; font-size: 9.1pt; margin-top: 1mm; }
    .edu-meta{ font-size: 9pt; color:#222; margin-top: 1mm; line-height: 1.25; }
    .edu-degree em{ font-style: italic; font-weight: 400; }

    /* ───────────── Languages (name + 5 dots) ───────────── */
    .lang-row{ display:flex; justify-content: space-between; align-items:center; margin: 1.5mm 0; }
    .lang-name{ font-size: 9.2pt; }
    .lang-dots{ display:flex; gap:4px; }
    .lang-dot{ width: 6px; height: 6px; border-radius: 50%; background:#111; }
    .lang-dot-empty{ background: transparent; border: 1px solid #999; }

    /* ───────────── Professional Experience ───────────── */
    .exp-entry{ margin-bottom: 5mm; }
    .exp-role{ font-weight: 800; font-size: 9.9pt; }
    .exp-company{ font-style: italic; font-size: 9.4pt; color:#222; margin-top: 1mm; }
    .exp-meta{ font-size: 8.9pt; color:#222; margin-top: 1mm; }

    .bullets{ margin-top: 2mm; padding-left: 16px; font-size: 9.2pt; }
    .bullets li{ margin-bottom: 1.2mm; }

    /* keep things clean */
    .sidebar .section{ margin-bottom: 9mm; }
  </style>
</head>

<body>
  <div class="page">

    <!-- HEADER -->
    <div class="header">
      <div class="name-row">
        <div class="name"><%= name %></div>
        <% if (jobTitle) { %>
          <div class="title"><%= jobTitle %></div>
        <% } %>
      </div>

      <% if (contactItems && contactItems.length) { %>
        <div class="contacts">
          <% contactItems.forEach(function(c){ %>
            <span class="contact-item">
              <% if (c.iconFile) { %><%- c.iconFile %><% } %>
              <% if (c.link) { %>
                <a href="<%= c.link %>"><%= c.text %></a>
              <% } else { %>
                <span><%= c.text %></span>
              <% } %>
            </span>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="grid">

      <!-- LEFT SIDEBAR -->
      <div class="sidebar">

        <% if (resume && resume.summary) { %>
          <div class="summary"><%= resume.summary %></div>
        <% } %>

        <% if (skillGroups && skillGroups.length) { %>
          <div class="section">
            <div class="section-head">
              <!-- skill icon (hand/wrench-ish) -->
              <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M22 19.6l-6.3-6.3a7 7 0 0 1-8.9-8.9l3.2 3.2 2.1-2.1-3.2-3.2a7 7 0 0 1 8.9 8.9L24 17.5 22 19.6zM2.6 21.4l7.3-7.3 2 2-7.3 7.3a1.4 1.4 0 0 1-2-2z"/>
              </svg>
              <div class="label">Skills</div>
            </div>
            <hr class="section-rule" />

            <% skillGroups.forEach(function(sg){ %>
              <div class="skill-group">
                <div>
                  <span class="skill-title"><%= sg.title %>:</span>
                  <span class="skill-items" style="word-wrap: break-word;"><% sg.skills.split('\n').filter(function(s){ return s.trim(); }).forEach(function(skill){ %><div><%= skill.trim() %></div><% }); %></span>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>

        <% if (resume.educations && resume.educations.length > 0) { %>
          <div class="section">
            <div class="section-head">
              <!-- graduation cap -->
              <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 3L1 9l11 6 9-4.9V17h2V9L12 3zm0 14L4 12.7V16c0 2.8 3.6 5 8 5s8-2.2 8-5v-3.3L12 17z"/>
              </svg>
              <div class="label">Education</div>
            </div>
            <hr class="section-rule" />
            <% resume.educations && resume.educations.forEach(function(edu) { %>
              <% if (edu.university) { %>
                <div class="edu-school"><%= edu.university %></div>
              <% } %>
              <% if (edu.degree) { %>
                <div class="edu-degree"><%= edu.degree %></div>
              <% } %>
              <% if (edu.gpa) { %><div style="font-size:8pt;color:#666">GPA: <%= edu.gpa %></div><% } %>
              <% if (edu.others) { %><div style="font-size:8pt;color:#666"><%= edu.others %></div><% } %>
              <div class="edu-meta">
                <% if (edu.duration) { %><div><%= edu.duration %></div><% } %>
                <% if (edu.location) { %><div><%= edu.location %></div><% } %>
              </div>
            <% }); %>
          </div>
        <% } %>

        <% if (resume.certificates && resume.certificates.length > 0) { %>
          <div class="section">
            <div class="section-head">
              <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/>
              </svg>
              <div class="label">Certificates</div>
            </div>
            <hr class="section-rule" />
            <% resume.certificates && resume.certificates.forEach(function(cert) { %>
              <div class="edu-school"><%= cert.name %></div>
              <% if (cert.org) { %><div class="edu-degree"><%= cert.org %></div><% } %>
              <div class="edu-meta">
                <% if (cert.date) { %><div><%= cert.date %></div><% } %>
              </div>
            <% }); %>
          </div>
        <% } %>

        <% if (languages && languages.length) { %>
          <div class="section">
            <div class="section-head">
              <!-- globe -->
              <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2a10 10 0 100 20 10 10 0 000-20zm7.9 9h-3.2a15.6 15.6 0 00-1.2-5A8.1 8.1 0 0119.9 11zM12 4.1c.9 1.2 1.8 3.4 2.2 6H9.8c.4-2.6 1.3-4.8 2.2-6zM4.1 13h3.2c.2 1.8.7 3.5 1.2 5A8.1 8.1 0 014.1 13zm3.2-2H4.1a8.1 8.1 0 014.4-5c-.5 1.5-1 3.2-1.2 5zm2.5 2h4.4c-.4 2.6-1.3 4.8-2.2 6-.9-1.2-1.8-3.4-2.2-6zm6.1 5c.5-1.5 1-3.2 1.2-5h3.2a8.1 8.1 0 01-4.4 5z"/>
              </svg>
              <div class="label">Languages</div>
            </div>
            <hr class="section-rule" />

            <% languages.forEach(function(l){ %>
              <div class="lang-row">
                <div class="lang-name"><%= l.name %></div>
                <% if (l.level > 1) { %>
                  <div class="lang-dots" aria-hidden="true">
                    <% for (var d = 0; d < 5; d++) { %>
                      <span class="lang-dot<%= d < l.level ? '' : ' lang-dot-empty' %>"></span>
                    <% } %>
                  </div>
                <% } %>
              </div>
            <% }) %>
          </div>
        <% } %>

      </div>

      <!-- RIGHT MAIN CONTENT -->
      <div class="main">

        <% if (experiences && experiences.length) { %>
          <div class="section">
            <div class="section-head">
              <!-- briefcase -->
              <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M10 2h4a2 2 0 012 2v2h4a2 2 0 012 2v10a2 2 0 01-2 2H4a2 2 0 01-2-2V8a2 2 0 012-2h4V4a2 2 0 012-2zm0 4h4V4h-4v2z"/>
              </svg>
              <div class="label">Professional Experience</div>
            </div>
            <hr class="section-rule" />

            <% experiences.forEach(function(exp){ %>
              <div class="exp-entry">
                <% if (exp.role) { %><div class="exp-role"><%= exp.role %><% if (exp.company) { %><span class="exp-company"> <%= exp.company %></span><% } %></div><% } %>

                <div class="exp-meta">
                  <% 
                    var metaParts = [];
                    if (exp.duration) metaParts.push(exp.duration);
                    if (exp.location) metaParts.push(exp.location);
                    var meta = metaParts.join(' | ');
                  %>
                  <% if (meta) { %><%= meta %><% } %>
                  <% if (exp.workPosition) { %> (<%= exp.workPosition %>)<% } %>
                </div>

                <% var items = (exp.items || []).filter(Boolean); %>
                <% if (items.length) { %>
                  <ul class="bullets">
                    <% items.forEach(function(it){ %>
                      <li><%= it %></li>
                    <% }) %>
                  </ul>
                <% } %>
              </div>
            <% }) %>
          </div>
        <% } %>

      </div>

    </div>
  </div>
</body>
</html>
